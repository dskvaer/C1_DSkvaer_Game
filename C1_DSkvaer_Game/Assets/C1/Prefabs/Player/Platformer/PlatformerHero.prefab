  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::C1.Platformer.Characters.PlatformerTouchInputSource
  inspectorDescription: "\u0418\u0441\u0442\u043E\u0447\u043D\u0438\u043A \u0432\u0432\u043E\u0434\u0430
    \u0434\u043B\u044F Android \u0438 UI-\u043A\u043D\u043E\u043F\u043E\u043A. \u041F\u0440\u0438\u0432\u044F\u0436\u0438\u0442\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B SetMove, PressJump, SetRun, SetCrouch, PressAttack
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u043A \u0432\u0438\u0440\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0441\u0442\u0438\u043A\u0443/\u043A\u043D\u043E\u043F\u043A\u0430\u043C Canvas.
    \u041A\u043E\u043C\u043F\u043E\u043D\u0435\u043D\u0442 \u0432\u044B\u0434\u0430\u0451\u0442
    \u0442\u0435 \u0436\u0435 \u043A\u043E\u043C\u0430\u043D\u0434\u044B, \u0447\u0442\u043E
    \u0438 PlayerPlatformerInputSource, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u043C\u043E\u0442\u043E\u0440 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430
    \u043D\u0435 \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043E\u0442 \u0442\u0438\u043F\u0430
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F."
  moveDeadZone: 0.12
  clearOneFrameButtonsInLateUpdate: 1
