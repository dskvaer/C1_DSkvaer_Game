  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::C1.Platformer.Characters.PlayerPlatformerInputSource
  inspectorDescription: "\u0418\u0441\u0442\u043E\u0447\u043D\u0438\u043A \u0432\u0432\u043E\u0434\u0430
    \u0434\u043B\u044F \u0438\u0433\u0440\u043E\u043A\u0430 \u0447\u0435\u0440\u0435\u0437
    Unity Input System. \u041F\u043E\u0434\u0445\u043E\u0434\u0438\u0442 \u0434\u043B\u044F
    \u043A\u043B\u0430\u0432\u0438\u0430\u0442\u0443\u0440\u044B, \u0433\u0435\u0439\u043C\u043F\u0430\u0434\u0430
    \u0438 Android, \u0435\u0441\u043B\u0438 \u044D\u043A\u0440\u0430\u043D\u043D\u044B\u0435
    \u043A\u043D\u043E\u043F\u043A\u0438 \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u044E\u0442
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F \u0432 PlayerInput. \u0414\u043B\u044F
    \u0440\u0443\u0447\u043D\u043E\u0439 \u043F\u0440\u0438\u0432\u044F\u0437\u043A\u0438
    UI-\u043A\u043D\u043E\u043F\u043E\u043A \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435
    PlatformerTouchInputSource."
