  m_Script: {fileID: 11500000, guid: 00ec1bc9439026642ae8ab05f6396628, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::C1.Platformer.Characters.PlatformerCharacterVitals
  inspectorDescription: "\u0411\u0430\u0437\u043E\u0432\u044B\u0435 \u0440\u0435\u0441\u0443\u0440\u0441\u044B
    \u043F\u043B\u0430\u0442\u0444\u043E\u0440\u043C\u0435\u0440\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430: \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435,
    \u0441\u0442\u0430\u043C\u0438\u043D\u0430, \u043F\u0430\u0442\u0440\u043E\u043D\u044B
    \u0438 \u043C\u0435\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B.
