  m_text: "\u042D\u043B\u0430\u0440\u0430 \u0422\u043E\u0440\u043D, \u044E\u043D\u0430\u044F
    \u043C\u0435\u0447\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430
    \u0438\u0437 \u043F\u0440\u0438\u0431\u0440\u0435\u0436\u043D\u043E\u0439 \u0434\u0435\u0440\u0435\u0432\u0443\u0448\u043A\u0438,
    \u043F\u043E\u0432\u0435\u0440\u0438\u043B\u0430 \u0432 \u043E\u0431\u0435\u0449\u0430\u043D\u0438\u044F
    \u043A\u0430\u043F\u0438\u0442\u0430\u043D\u0430 \u0411\u0430\u0440\u043A\u0443\u0441\u0430.
    \u0415\u0451 \u0436\u0430\u0436\u0434\u0430 \u043F\u0440\u0438\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0439
    \u043F\u0440\u0438\u0432\u0435\u043B\u0430 \u0435\u0451 \u043D\u0430 \u0431\u043E\u0440\u0442
    \u041C\u043E\u0440\u0441\u043A\u043E\u0433\u043E \u044F\u0441\u0442\u0440\u0435\u0431\u0430"
